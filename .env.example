# ─────────────────────────────────────────────
# 🌐 App Environment
# ─────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────
# 🔗 Frontend Public URLs (Client Safe)
# MUST start with NEXT_PUBLIC_
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app
NEXT_PUBLIC_API_URL=https://your-backend.com/api
NEXT_PUBLIC_BACKEND_URL=https://your-backend.com

# Auth (Frontend)
NEXT_PUBLIC_AUTH_URL=https://your-frontend.vercel.app/api/auth

# Stripe (Public Key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx

# Cloudinary (Public)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─────────────────────────────────────────────
# 🔐 Server Only (NEVER expose to frontend)
# ─────────────────────────────────────────────
BACKEND_URL=https://your-backend.com
API_URL=https://your-backend.com
AUTH_URL=https://your-backend.com/api/auth

FRONTEND_URL=https://your-frontend.vercel.app

# Auth Secret
BETTER_AUTH_SECRET=your_super_secret_key
BETTER_AUTH_URL=https://your-frontend.vercel.app/api/auth

# ─────────────────────────────────────────────
# 💳 Payments (Server Only)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# ☁️ Cloudinary (Server)
# ─────────────────────────────────────────────
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxx

# ─────────────────────────────────────────────
# 🧪 Optional / Debug
# ─────────────────────────────────────────────
NEXT_PUBLIC_TEST=test-value